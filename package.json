{
  "name": "credit-heatmap",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm --filter @credit-generator/core typecheck && tsc --noEmit",
    "test": "pnpm --filter @credit-generator/core test",
    "test:coverage": "pnpm --filter @credit-generator/core test:coverage",
    "test:e2e": "playwright test",
    "clean": "rm -rf .next packages/core/dist",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@credit-generator/core": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@nivo/core": "^0.87.0",
    "@nivo/heatmap": "^0.87.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.17",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^10.1.1",
    "lucide-react": "^1.7.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4.0.6",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lefthook": "^2.1.9",
    "tailwindcss": "^4.0.6",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
