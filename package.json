{
  "name": "credit-generator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @credit-generator/core build && next dev --port 3000",
    "build": "pnpm --filter @credit-generator/core build && next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm --filter @credit-generator/core build && tsc --noEmit",
    "test": "pnpm --filter @credit-generator/core test",
    "test:e2e": "playwright test",
    "clean": "rm -rf .next packages/core/dist",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@credit-generator/core": "workspace:*",
    "@nivo/core": "^0.87.0",
    "@nivo/heatmap": "^0.87.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^10.1.1",
    "lucide-react": "^1.7.0",
    "next": "15.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4.0.6",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cspell": "^10.0.1",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.8",
    "tailwindcss": "^4.0.6",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,json,md,css,scss,html}": "biome check --write --no-errors-on-unmatched",
    "*.{md,txt}": "cspell --no-progress"
  }
}
