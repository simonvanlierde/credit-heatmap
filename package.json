{
  "name": "credit-heatmap",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "next dev --webpack --port 3000",
    "build": "next build --webpack",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm --filter @credit-generator/core typecheck && tsc --noEmit",
    "test": "pnpm --filter @credit-generator/core test",
    "test:coverage": "pnpm --filter @credit-generator/core test:coverage",
    "test:e2e": "playwright test",
    "clean": "rm -rf .next packages/core/dist",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@credit-generator/core": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@nivo/core": "^0.99.0",
    "@nivo/heatmap": "^0.99.0",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-hover-card": "^1.1.18",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-switch": "^1.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^11.1.8",
    "lucide-react": "^1.22.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "lefthook": "^2.1.9",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.106.0"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.1",
      "postcss": "^8.5.16"
    }
  }
}
