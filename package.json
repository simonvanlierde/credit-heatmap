{
  "name": "credit-generator",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "cspell": "^10.0.1",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.8",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,json,md,css,scss,html}": "biome check --write --no-errors-on-unmatched",
    "*.{md,txt}": "cspell --no-progress"
  },
  "packageManager": "pnpm@9.15.4"
}
