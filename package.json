{
  "name": "credit-heatmap",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "next dev --webpack --port 3000",
    "build": "next build --webpack",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm --filter @credit-generator/core typecheck && tsc --noEmit",
    "test": "pnpm --filter @credit-generator/core test",
    "test:coverage": "pnpm --filter @credit-generator/core test:coverage",
    "test:e2e": "playwright test",
    "clean": "rm -rf .next packages/core/dist",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@credit-generator/core": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-switch": "^1.3.3",
    "clsx": "^2.1.1",
    "immer": "^11.1.15",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.10",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "wrangler": "^4.112.0"
  }
}
